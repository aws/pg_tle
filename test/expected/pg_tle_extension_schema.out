    $_pgtle_$
        CREATE OR REPLACE FUNCTION my_tle_func_4() RETURNS INT LANGUAGE SQL AS
            'SELECT 1';
    $_pgtle_$,
    '{my_tle_3}', 'my_tle_schema_2');
