SELECT pgtle.install_extension('my_tle', '1.0', 'My TLE',
    $_pgtle_$
        CREATE OR REPLACE FUNCTION my_tle_func() RETURNS INT LANGUAGE SQL AS
            'SELECT 1';
    $_pgtle_$,
    '{}', 'my_tle_schema_1');
